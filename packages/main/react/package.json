{
  "name": "@pelatformui/react",
  "version": "1.1.0",
  "description": "A Modern and Minimal React UI Library built with TailwindCSS.",
  "author": "Pelatform Dev",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    "./css": "./css/theme.css",
    "./css/*": "./css/components/*.css",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./animation": {
      "types": "./dist/animation.d.ts",
      "default": "./dist/animation.js"
    },
    "./aria": {
      "types": "./dist/aria.d.ts",
      "default": "./dist/aria.js"
    },
    "./base": {
      "types": "./dist/base.d.ts",
      "default": "./dist/base.js"
    },
    "./default": {
      "types": "./dist/default.d.ts",
      "default": "./dist/default.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "default": "./dist/hooks.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "default": "./dist/components.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "clean:all": "rimraf .turbo dist node_modules",
    "dev": "tsup --watch",
    "build": "tsup",
    "types:check": "tsc --noEmit"
  },
  "homepage": "https://github.com/devpelatform/ui.git",
  "files": [
    "css",
    "dist"
  ],
  "keywords": [
    "pelatform",
    "ui",
    "tailwindcss",
    "react"
  ],
  "dependencies": {
    "@pelatformui/animation": "workspace:*",
    "@pelatformui/aria": "workspace:*",
    "@pelatformui/base": "workspace:*",
    "@pelatformui/default": "workspace:*",
    "@pelatformui/general": "workspace:*",
    "@pelatformui/hook": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-query": "^5.90.11",
    "lucide-react": "^0.555.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "react": "^19.2.0",
    "tailwindcss": "^4.1.17",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0 || >=19.0.0-rc.0",
    "react-dom": ">=18.0.0 || >=19.0.0-rc.0",
    "tailwindcss": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
